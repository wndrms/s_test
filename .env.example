# Lumos environment configuration
# Copy to .env and fill in values

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lumos

# AES-256-GCM key — generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_-base64_32

# Server
LISTEN_ADDR=0.0.0.0:3000

# Authentication (optional)
# DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# Logging
RUST_LOG=info

# KIS (한국투자증권) — stored encrypted in DB, these are for local dev only
# KIS_ENV=paper            # paper (모의투자, 기본값) | real (실거래)
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=          # 계좌번호 앞 8자리
# KIS_ACCOUNT_PRODUCT=01   # 계좌상품코드 뒤 2자리 (보통 01)

# LLM (서버 기본 프로바이더 - 사용자별 키는 API를 통해 등록)
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# Telegram
# TELEGRAM_BOT_TOKEN=
