# Lumos environment configuration
# Copy to .env and fill in values

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lumos

# AES-256-GCM key — generate with: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_-base64_32

# Server
LISTEN_ADDR=0.0.0.0:3000

# Logging
RUST_LOG=info

# KIS (한국투자증권) — stored encrypted in DB, these are for local dev only
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIS_ACCOUNT_NO=
# KIS_ACCOUNT_PRODUCT=01

# LLM
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=

# Telegram
# TELEGRAM_BOT_TOKEN=
