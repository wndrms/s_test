{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockworldcup.local/schemas/evidence_card.schema.json",
  "title": "EvidenceCard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "symbol",
    "source_type",
    "source_name",
    "title",
    "summary",
    "sentiment",
    "importance_score",
    "reliability_score",
    "as_of"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "symbol": { "type": "string", "minLength": 1 },
    "market": { "type": "string", "enum": ["KRX", "NASDAQ", "NYSE", "AMEX", "UNKNOWN"] },
    "source_type": {
      "type": "string",
      "enum": ["price", "technical", "account", "news", "disclosure", "financial", "community", "risk", "manual"]
    },
    "source_name": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1, "maxLength": 240 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1200 },
    "url": { "type": ["string", "null"] },
    "sentiment": { "type": "string", "enum": ["positive", "neutral", "negative", "mixed", "unknown"] },
    "importance_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "reliability_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "as_of": { "type": "string", "format": "date-time" },
    "data_warning": { "type": ["string", "null"], "maxLength": 500 }
  }
}
